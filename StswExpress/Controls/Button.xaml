<Button x:Class="StswExpress.Controls.Button"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:StswExpress.Controls"
        xmlns:g="clr-namespace:StswExpress.Globals"
        mc:Ignorable="d" d:DesignWidth="100"
        HorizontalContentAlignment="Left"
        VerticalAlignment="Top">
    <Button.Resources>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="{Binding Source={x:Static g:Properties.Size}, Converter={g:conv_Size}, ConverterParameter=0.5}"/>
        </Style>
    </Button.Resources>
    <StackPanel Orientation="Horizontal">
        <Image Height="{Binding Source={x:Static g:Properties.Size}, Converter={g:conv_Size}, ConverterParameter=2}"
               Margin="{Binding Source={x:Static g:Properties.Size}, Converter={g:conv_Size}, ConverterParameter=0.3}"
               Source="{Binding Icon, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Button}}"/>
        <Label Content="{Binding Text, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Button}}"
               FontSize="{Binding Source={x:Static g:Properties.Size}}"
               VerticalAlignment="Center"
               Visibility="{Binding TextVisibility, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Button}, Converter={g:conv_BoolToVisibility}}"/>
    </StackPanel>
</Button>