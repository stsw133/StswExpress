<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:se="clr-namespace:StswExpress">

    <Style TargetType="{x:Type se:StswWindowsPanel}">

        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="CornerClipping" Value="True" />

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <Canvas Background="Transparent"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type se:StswWindowsPanel}">

                    <!-- main -->
                    <se:StswBorder x:Name="OPT_MainBorder"
                                   Background="{TemplateBinding Background}"
                                   BorderBrush="{TemplateBinding BorderBrush}"
                                   BorderThickness="{TemplateBinding BorderThickness}"
                                   CornerClipping="{TemplateBinding CornerClipping}"
                                   CornerRadius="{TemplateBinding CornerRadius}" >
                        <DockPanel>
                            <Grid Background="Blue"
                                  Height="50"
                                  DockPanel.Dock="Top">
                                <ListBox x:Name="PART_TabList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas AllowDrop="True"/>

                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>

                                            <se:StswBorder Background="Pink" Width="90" Height="40"
                                                           Margin="0 5">
                                                <TextBlock Text="{Binding}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </se:StswBorder>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                            <ItemsPresenter x:Name="PART_WindowsHost"/>
                        </DockPanel>
                    </se:StswBorder>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style TargetType="{x:Type se:StswWindowPanelItem}">

        <Setter Property="MinWidth" Value="300" />
        <Setter Property="Width" Value="500" />
        <Setter Property="MinHeight" Value="200" />
        <Setter Property="Height" Value="300" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type se:StswWindowPanelItem}">
                    <se:StswBorder Width="{TemplateBinding Width}"
                                   Height="{TemplateBinding Height}"
                                   Background="Red"
                                   BorderThickness="0">

                        <Grid>

                            <!-- TOP -->
                            <Rectangle x:Name="PART_TopResizeBorder"
                                       Height="2"
                                       Fill="Purple"
                                       VerticalAlignment="Top"
                                       Margin="2 0"
                                       Cursor="SizeNS"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- BOTTOM -->
                            <Rectangle x:Name="PART_BottomResizeBorder"
                                       Height="2"
                                       Fill="Purple"
                                       VerticalAlignment="Bottom"
                                       Margin="2 0"
                                       Cursor="SizeNS"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- LEFT -->
                            <Rectangle x:Name="PART_LeftResizeBorder"
                                       Width="2"
                                       Fill="Purple"
                                       HorizontalAlignment="Left"
                                       Margin="0 2"
                                       Cursor="SizeWE"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- RIGHT -->
                            <Rectangle x:Name="PART_RightResizeBorder"
                                       Width="2"
                                       Fill="Purple"
                                       HorizontalAlignment="Right"
                                       Margin="0 2"
                                       Cursor="SizeWE"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- TOP-RIGHT -->
                            <Rectangle x:Name="PART_TopRightResizeBorder"
                                       Width="2"
                                       Height="2"
                                       Fill="Purple"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Cursor="SizeNESW"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- TOP-LEFT -->
                            <Rectangle x:Name="PART_TopLeftResizeBorder"
                                       Width="2"
                                       Height="2"
                                       Fill="Purple"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Cursor="SizeNWSE"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- BOTTOM-RIGHT -->
                            <Rectangle x:Name="PART_BottomRightResizeBorder"
                                       Width="2"
                                       Height="2"
                                       Fill="Purple"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>
                            <!-- BOTTOM-LEFT -->
                            <Rectangle x:Name="PART_BottomLeftResizeBorder"
                                       Width="2"
                                       Height="2"
                                       Fill="Purple"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNESW"
                                       Visibility="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static se:StswIfElseConverter.Instance}, ConverterParameter='Maximized~Collapsed~Visible'}"/>

                            <Grid Margin="2 2 2 2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel x:Name="PART_BarPanel" Background="Gray">
                                    <se:StswSubButton x:Name="PART_CloseBtn"
                                                      DockPanel.Dock="Right"
                                                      IconData="{x:Static se:StswIcons.Close}"
                                                      IconFill="{DynamicResource StswColor.Negative}" />
                                    <se:StswSubButton x:Name="PART_MaximizeBtn"
                                                      DockPanel.Dock="Right"
                                                      HorizontalAlignment="Right"
                                                      IconData="{x:Static se:StswIcons.WindowMaximize}"
                                                      IconFill="{DynamicResource StswColor.Nutral}" />
                                    <se:StswSubButton x:Name="PART_MinimizeBtn"
                                                      DockPanel.Dock="Right"
                                                      IconData="{x:Static se:StswIcons.WindowMinimize}"
                                                      IconFill="{DynamicResource StswColor.Nutral}" />
                                    <Image DockPanel.Dock="Left"/>
                                    <ContentControl />
                                </DockPanel>

                                <ContentPresenter Grid.Row="1"
                                                  Focusable="False"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>

                        </Grid>
                        

                    </se:StswBorder>
                    <ControlTemplate.Triggers>
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="PART_MaximizeBtn" Property="IconData" Value="{x:Static se:StswIcons.WindowRestore}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="MinimizedStswWindowPanelItem" TargetType="{x:Type se:StswReorderListBoxItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type se:StswReorderListBoxItem}">
                    <se:StswBorder BorderThickness="2">
                        <se:StswText Text="Zakładka" />
                    </se:StswBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>