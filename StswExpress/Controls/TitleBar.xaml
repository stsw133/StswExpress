<UserControl x:Class="StswExpress.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:g="clr-namespace:StswExpress.Globals"
             mc:Ignorable="d" d:DesignWidth="300"
             Loaded="UserControl_Loaded">
    <!-- titleBar -->
    <DockPanel x:Name="titleBar" Background="{Binding Source={x:Static g:Properties.ThemeColor}}" MouseDown="titleBar_MouseDown" WindowChrome.IsHitTestVisibleInChrome="True">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
            <Button x:Name="btnMinimize"
                    Background="{Binding Source={x:Static g:Properties.ThemeColor}, Converter={g:conv_Color}, ConverterParameter=-0.25}"
                    BorderThickness="0"
                    IsEnabled="{Binding ResizeMode, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={g:conv_Compare}, ConverterParameter=!NoResize}"
                    Visibility="{Binding ResizeMode, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={g:conv_Compare}, ConverterParameter=!NoResize}"
                    Width="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=3.5}"
                    Click="miMinimize_Click">
                <Image Margin="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=0.25}" Height="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=1.75}" Source="/Resources/icon32_minimize.ico"/>
            </Button>
            <Button x:Name="btnResize"
                    Background="{Binding Source={x:Static g:Properties.ThemeColor}, Converter={g:conv_Color}, ConverterParameter=-0.25}"
                    BorderThickness="0"
                    IsEnabled="{Binding ResizeMode, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={g:conv_Compare}, ConverterParameter=CanResize}"
                    Visibility="{Binding ResizeMode, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={g:conv_Compare}, ConverterParameter=CanResize}"
                    Width="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=3.5}"
                    Click="miResize_Click">
                <Image Margin="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=0.25}" Height="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=1.75}" Source="{Binding WindowState, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={g:conv_StringToString}, ConverterParameter=Maximized~/Resources/icon32_restoredown.ico~/Resources/icon32_maximize.ico}"/>
            </Button>
            <Button x:Name="btnClose"
                    Background="{Binding Source={x:Static g:Properties.ThemeColor}, Converter={g:conv_Color}, ConverterParameter=-0.25}"
                    BorderThickness="0"
                    Width="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=3.5}"
                    Click="miClose_Click">
                <Image Margin="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=0.25}" Height="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=1.75}" Source="/Resources/icon32_close.ico"/>
            </Button>
        </StackPanel>
        <Grid Margin="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=0.25}">
            <Image Height="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=1.75}" Source="{Binding Icon, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
            <Image Height="{Binding Source={x:Static g:Properties.iSize}, Converter={g:conv_Size}, ConverterParameter=0.85}" Source="{Binding SubIcon, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>
        <Label Content="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" VerticalContentAlignment="Center" Foreground="White"/>
    </DockPanel>
    <UserControl.ContextMenu>
        <ContextMenu DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <!--<MenuItem x:Name="miRestoreDown" Header="Przywróć" Click="miResize_Click" IsEnabled="{Binding WindowState, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={g:conv_Compare}, ConverterParameter=Maximized}"/>-->
            <MenuItem x:Name="miSetCenter" Header="Wyśrodkuj na ekranie" Click="miSetCenter_Click"/>
            <MenuItem x:Name="miDefaultSize" Header="Domyślny rozmiar" Click="miDefaultSize_Click" IsEnabled="{Binding IsEnabled, ElementName=btnResize}"/>
            <MenuItem x:Name="miMinimize" Header="Minimalizuj" Click="miMinimize_Click" IsEnabled="{Binding IsEnabled, ElementName=btnMinimize}"/>
            <MenuItem x:Name="miMaximize" Header="Maksymalizuj" Click="miResize_Click" IsEnabled="{Binding IsEnabled, ElementName=btnResize}"/>
            <Separator/>
            <MenuItem x:Name="miClose" Header="Zamknij okno" Click="miClose_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>
