<UserControl x:Class="StswExpress.Controls.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:g="clr-namespace:StswExpress.Globals"
             mc:Ignorable="d" d:DesignWidth="100"
             VerticalAlignment="Top">
    <DockPanel>
        <UniformGrid DockPanel.Dock="{Binding ButtonsAlignment, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}" Columns="1">
            <Button Content="▲"
                    FontSize="{Binding FontSize, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Converter={g:conv_Size}, ConverterParameter=0.5}"
                    Padding="{Binding FontSize, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Converter={g:conv_Size}, ConverterParameter=0.5;0}"
                    Click="btnUp_Click"/>
            <Button Content="▼"
                    FontSize="{Binding FontSize, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Converter={g:conv_Size}, ConverterParameter=0.5}"
                    Padding="{Binding FontSize, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Converter={g:conv_Size}, ConverterParameter=0.5;0}"
                    Click="btnDown_Click"/>
        </UniformGrid>
        <TextBox Text="{Binding Value, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                 HorizontalContentAlignment="{Binding ValueAlignment, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                 VerticalContentAlignment="Center"
                 TextChanged="tbNumeric_TextChanged"/>
    </DockPanel>
</UserControl>
